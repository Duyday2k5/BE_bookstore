{
    "compilerOptions": {
        "baseUrl": ".",
        "target": "es2020",
        "module": "commonjs",
        "lib": [
            "es2020"
        ],
        "allowJs": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": false,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": false,
        "sourceMap": false
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "test",
        "**/*spec.js"
    ]
}