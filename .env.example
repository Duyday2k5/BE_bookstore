# =============================================
# BOOKSTORE BACKEND - Environment Variables
# Copy file này thành .env và điền giá trị
# =============================================

# Port chạy ứng dụng backend (Render tự set PORT tự động)
PORT=8080

# Môi trường Node.js: development | production
NODE_ENV=production

# MongoDB Atlas connection string
MONGO_DB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Mật khẩu mặc định khi tạo fake data cho user
MIGRATION_USER_PASSWORD=123456

# JWT Access Token
JWT_ACCESS_SECRET=YOUR_RANDOM_SECRET_ACCESS
JWT_ACCESS_EXPIRE_IN=10h

# JWT Refresh Token
JWT_REFRESH_SECRET=YOUR_RANDOM_SECRET_REFRESH
JWT_REFRESH_EXPIRE_IN=1d
